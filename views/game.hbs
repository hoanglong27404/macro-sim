<div class="game-screen" id="gameScreen">
  <!-- Progress Bar -->
  <div class="progress-bar-wrap">
    <div class="progress-meta">
      <span id="moduleLabel" class="module-label">MODULE 1</span>
      <span id="progressText" class="progress-text">1 / 10</span>
    </div>
    <div class="progress-track">
      <div class="progress-fill" id="progressFill" style="width: 10%"></div>
    </div>
  </div>

  <!-- Question Card -->
  <div class="question-card" id="questionCard">
    <div class="question-header">
      <div class="event-year" id="eventYear">2008</div>
      <h2 class="question-title" id="questionTitle">Khủng hoảng Tài chính Toàn cầu</h2>
    </div>

    <div class="context-box" id="contextBox">
      <div class="context-icon">📋</div>
      <p class="context-text" id="contextText"></p>
    </div>

    <div class="choices-list" id="choicesList">
      <!-- Injected by JS -->
    </div>
  </div>

  <!-- Navigation -->
  <div class="game-nav">
    <button class="nav-btn btn-prev" id="prevBtn" onclick="prevQuestion()" style="visibility:hidden">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Quay lại
    </button>
    <div class="question-dots" id="questionDots"></div>
    <button class="nav-btn btn-next" id="nextBtn" onclick="nextQuestion()" disabled>
      Tiếp theo
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </button>
  </div>

  <script>
    const QUESTIONS = {{{questionsJson}}};
    const state = JSON.parse(sessionStorage.getItem('gameState') || 'null') || {
      gender: 'male',
      playerName: '',
      answers: [],
      currentIndex: 0,
    };

    if (!sessionStorage.getItem('gameState')) {
      const params = new URLSearchParams(window.location.search);
      state.gender = params.get('gender') || 'male';
      state.playerName = params.get('name') || '';
    }

    document.body.className = `theme-${state.gender}`;
  </script>
</div>
