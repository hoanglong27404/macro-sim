<div class="result-screen" id="resultScreen">

  <!-- Loading State -->
  <div class="loading-state" id="loadingState">
    <div class="loading-orb"></div>
    <div class="loading-rings">
      <div class="ring ring-1"></div>
      <div class="ring ring-2"></div>
      <div class="ring ring-3"></div>
    </div>
    <p class="loading-title">Đang phân tích tư duy kinh tế...</p>
    <p class="loading-sub">Gemini AI đang xử lý 10 lựa chọn của bạn</p>
  </div>

  <!-- Result Content -->
  <div class="result-content" id="resultContent" style="display:none">

    <!-- Verdict Banner -->
    <div class="verdict-banner" id="verdictBanner">
      <div class="verdict-badge" id="verdictBadge">
        <span class="verdict-flag" id="verdictFlag"></span>
        <div class="verdict-text-wrap">
          <span class="verdict-label">Hệ tư tưởng của bạn</span>
          <span class="verdict-name" id="verdictName"></span>
        </div>
      </div>
      <div class="consistency-ring-wrap">
        <svg class="consistency-ring" viewBox="0 0 80 80">
          <circle class="ring-bg" cx="40" cy="40" r="34" />
          <circle class="ring-progress" id="consistencyRing" cx="40" cy="40" r="34" />
        </svg>
        <span class="consistency-pct" id="consistencyPct">0%</span>
        <span class="consistency-label">Nhất quán</span>
      </div>
    </div>

    <!-- Score Chart -->
    <div class="score-section">
      <h3 class="section-title">Phân bổ Tư duy</h3>
      <div class="score-bars" id="scoreBars">
        <!-- Injected by JS -->
      </div>
    </div>

    <!-- AI Analysis -->
    <div class="analysis-section">
      <div class="analysis-header">
        <span class="ai-badge">✦ Gemini AI</span>
        <h3 class="section-title">Phân tích Chuyên sâu</h3>
      </div>
      <div class="analysis-card" id="analysisCard">
        <p class="analysis-text" id="analysisText"></p>
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="comparison-section">
      <h3 class="section-title">Bảng So sánh 3 Hệ thống</h3>
      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="col-criteria">Tiêu chí</th>
              <th class="col-free">🇺🇸 KTTT Tự do</th>
              <th class="col-socialist">🇨🇳 KTTT XHCN</th>
              <th class="col-vn">🇻🇳 KTTT ĐHXHCN</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="criteria-cell">Vai trò Nhà nước</td>
              <td>Tối thiểu — "Bàn tay vô hình" dẫn đường</td>
              <td>Tuyệt đối — Nhà nước chỉ huy mọi thứ</td>
              <td>Định hướng — Nhà nước giữ "mỏ neo" chiến lược</td>
            </tr>
            <tr>
              <td class="criteria-cell">Sở hữu tư liệu</td>
              <td>Tư nhân chiếm ưu thế tuyệt đối</td>
              <td>Quốc hữu hóa toàn diện</td>
              <td>Đa dạng: Nhà nước + Tư nhân + FDI cùng tồn tại</td>
            </tr>
            <tr>
              <td class="criteria-cell">Xử lý khủng hoảng</td>
              <td>Để thị trường tự đào thải</td>
              <td>Mệnh lệnh hành chính cứng nhắc</td>
              <td>Can thiệp có chọn lọc, kết hợp thị trường</td>
            </tr>
            <tr>
              <td class="criteria-cell">Mục tiêu cốt lõi</td>
              <td>Tối đa hóa hiệu quả thị trường & lợi nhuận</td>
              <td>Công bằng xã hội tuyệt đối, xóa tư hữu</td>
              <td>"Dân giàu, Nước mạnh, Công bằng, Văn minh"</td>
            </tr>
            <tr>
              <td class="criteria-cell">Ưu điểm nổi bật</td>
              <td>Sáng tạo, cạnh tranh, năng động cao</td>
              <td>Ổn định xã hội, phân phối đồng đều</td>
              <td>Linh hoạt, vừa tăng trưởng vừa công bằng</td>
            </tr>
            <tr>
              <td class="criteria-cell">Hạn chế chính</td>
              <td>Bất bình đẳng cao, khủng hoảng chu kỳ</td>
              <td>Kém năng động, dễ quan liêu, trì trệ</td>
              <td>Đòi hỏi thể chế pháp lý cực kỳ minh bạch</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Answer Review -->
    <div class="review-section">
      <h3 class="section-title">Ôn lại Lựa chọn của Bạn</h3>
      <div class="answer-list" id="answerList">
        <!-- Injected by JS -->
      </div>
    </div>

    <!-- Actions -->
    <div class="result-actions">
      <button class="action-btn btn-restart" onclick="restartGame()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M1 4v6h6M23 20v-6h-6"/>
          <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/>
        </svg>
        Chơi lại
      </button>
      <button class="action-btn btn-share" onclick="shareResult()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
        </svg>
        Chia sẻ Kết quả
      </button>
    </div>

  </div>
</div>
